{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Générer le site",
            "type": "shell",
            "command": "python -m mkdocs serve --livereload",
            "problemMatcher": [
                "$python"
            ]
        },
        {
            "label": "Afficher le site",
            "type": "shell",
            "command": "start",
            "args": [
                "http://127.0.0.1:8000"
            ],
            "problemMatcher": []
        }
    ]
}